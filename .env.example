# Copy to .env and fill in. .env is gitignored — never commit it.

# ── Neo4j (the graph store) ───────────────────────────────────────
NEO4J_PASSWORD=change-me-to-a-strong-password
# In Docker the app reaches Neo4j by its compose service name (default below).
# NEO4J_URI=bolt://neo4j:7687         # native/remote: bolt://localhost:7687
# NEO4J_USER=neo4j

# ── Collection / "Run Now" watcher ───────────────────────────────
# Device SSH credentials the collector uses. The bundled containerlab demo
# accepts admin/admin, which the watcher assumes by default — uncomment and
# change these only for a real network.
# NETCOPILOT_SSH_USERNAME=admin
# NETCOPILOT_SSH_PASSWORD=admin
# NETCOPILOT_ENABLE_PASSWORD=
# FortiGate REST token (demo edge-fw-01, or your firewall). Without it the
# FortiGate device is skipped; the rest of the run still completes.
# NETCOPILOT_FORTIGATE_API_TOKEN=
#
# Multiple firewalls / multiple tenants: the single vars above are the default,
# but each device can name its OWN secret in the inventory via ${ENV_VAR}, so the
# secrets live here in .env (never in the inventory file). Works for the SSH
# username/password/enable AND the FortiGate api_token. Example inventory entries:
#   - { name: edge-fw-01, mgmt_ip: 10.0.0.1, os: fortios, api_token: ${FW1_TOKEN} }
#   - { name: edge-fw-02, mgmt_ip: 10.0.0.2, os: fortios, api_token: ${FW2_TOKEN} }
#   - { name: core-01,    mgmt_ip: 10.0.0.3, os: ios-xe,  password:  ${SITE_B_PW} }
# then define FW1_TOKEN / FW2_TOKEN / SITE_B_PW below.
# Watcher target — defaults to the containerlab demo. Override for your network.
# NETCOPILOT_INVENTORY=demo/containerlab/inventory.yaml
# NETCOPILOT_SITE=demo

# Optional: reach a lab/network behind an SSH jump host (sshuttle sidecar). Enable
# with `-f docker-compose.tunnel.yml` (see that file). Lets the in-container
# watcher collect devices it otherwise couldn't route to.
# SSHUTTLE_HOST=root@10.0.0.5        # user@jump-host
# SSHUTTLE_SUBNET=192.0.2.0/24       # lab subnet to route through it
# SSHUTTLE_EXCLUDE=10.0.0.5          # don't tunnel the jump host itself
# SSHUTTLE_PASSWORD=                 # jump-host password

# ── LLM provider: "claude" or "ollama" ───────────────────────────
NETCOPILOT_LLM=claude

# Claude (Anthropic API):
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# Ollama (local, OpenAI-compatible):
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# Any model in models.yaml that uses a cloud provider reads its key from the
# env var named by that entry's `api_key_env`. Set the ones you use:
# ANTHROPIC_API_KEY=          # Claude entries
# OPENAI_API_KEY=             # GPT entries
# GEMINI_API_KEY=             # Gemini entries
# VLLM_BASE_URL=http://host.docker.internal:8000/v1   # a local/VM LLM from a container

# ── Email reports (BYO SMTP — any RFC-5321 server, not just Gmail) ─
# Without these, reports still generate as PDF; only emailing is disabled.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=          # defaults to SMTP_USER
# SMTP_FROM_NAME=NetCopilot

# ── Telegram bot (BYO — optional) ─────────────────────────────────
# Token from @BotFather. Without it the telegram service exits cleanly.
# TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all).
# TELEGRAM_ALLOWED_USERS=

# ── RAG over your own vendor PDFs (optional) ──────────────────────
# The vector store ships empty. Ingest your PDFs after `up`:
#   docker compose exec dashboard \
#     python -m netcopilot.rag.ingest --docs-dir /app/knowledge_base
# Mount a host folder of PDFs to /app/knowledge_base (see docker-compose.yml).
