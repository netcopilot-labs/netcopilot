# Copy to .env and fill in. .env is gitignored — never commit it.

# ── Neo4j (the graph store) ───────────────────────────────────────
NEO4J_PASSWORD=change-me-to-a-strong-password
# In Docker the app reaches Neo4j by its compose service name (default below).
# NEO4J_URI=bolt://neo4j:7687         # native/remote: bolt://localhost:7687
# NEO4J_USER=neo4j

# ── Collection / "Run Now" watcher ───────────────────────────────
# Device SSH login the collector uses for YOUR network (single-network case).
# NETCOPILOT_SSH_USERNAME=
# NETCOPILOT_SSH_PASSWORD=
# NETCOPILOT_ENABLE_PASSWORD=                       # only if your devices use one
# FortiGate REST token — only if you have a FortiGate. Without it the firewall is
# skipped; the rest of the run still completes.
# NETCOPILOT_FORTIGATE_API_TOKEN=
#
# Multiple networks / tenants: give each one a self-contained folder
# inventory/<tenant>/ with lab.yaml + its own credentials.env (SSH creds +
# FortiGate token), so nothing here is shared — see README / INSTALLATION.md.
# (A single device can also name a secret inline via ${ENV_VAR}.)
#
# Headless watcher target (the dashboard's inventory picker overrides this per
# run; set it only if you run collection without the dashboard).
# NETCOPILOT_INVENTORY=inventory/my-network.yaml
# NETCOPILOT_SITE=
# Production: hide the bundled demo labs from the inventory dropdown (no rebuild).
# NETCOPILOT_HIDE_DEMOS=1

# ── LLM provider: "claude" or "ollama" ───────────────────────────
NETCOPILOT_LLM=claude

# Claude (Anthropic API):
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# Ollama (local, OpenAI-compatible):
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# Any model in models.yaml that uses a cloud provider reads its key from the
# env var named by that entry's `api_key_env`. Set the ones you use:
# ANTHROPIC_API_KEY=          # Claude entries
# OPENAI_API_KEY=             # GPT entries
# GEMINI_API_KEY=             # Gemini entries
# VLLM_BASE_URL=http://host.docker.internal:8000/v1   # a local/VM LLM from a container

# ── Email reports (BYO SMTP — any RFC-5321 server, not just Gmail) ─
# Without these, reports still generate as PDF; only emailing is disabled.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=          # defaults to SMTP_USER
# SMTP_FROM_NAME=NetCopilot

# ── Telegram bot (BYO — optional) ─────────────────────────────────
# Token from @BotFather. Without it the telegram service exits cleanly.
# TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all).
# TELEGRAM_ALLOWED_USERS=

# ── RAG over your own vendor PDFs (optional) ──────────────────────
# The vector store ships empty. Ingest your PDFs after `up`:
#   docker compose exec dashboard \
#     python -m netcopilot.rag.ingest --docs-dir /app/knowledge_base
# Mount a host folder of PDFs to /app/knowledge_base (see docker-compose.yml).
