# ── Internal / private (never published) ─────────────────────────
/CLAUDE.md
/internal/
/.claude/
*.local.*

# ── Data & secrets (BYO — never shipped) ─────────────────────────
/runs/
# Ship the (empty) BYO dirs so a fresh clone owns them — otherwise Docker
# bind-mount auto-creates them root-owned and the user can't drop files in.
# Ignore their contents, keep the README placeholder.
/inventory/*
!/inventory/README.md
/data/
# RAG ChromaDB store: default path is package-relative (rag/store.py), so a user
# who ingests their own docs would otherwise commit the embeddings. Ignore it.
src/netcopilot/data/
/knowledge_base/*
!/knowledge_base/README.md
.env
.env.*
!.env.example
# User's model registry (may reference internal endpoints); ship models.example.yaml.
/models.yaml
*.pem
*.key

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ── Node / frontend ──────────────────────────────────────────────
node_modules/
dist/
build/
*.log

# ── Caches / model weights ───────────────────────────────────────
.cache/
*.bin
*.safetensors

# ── IDE / OS ─────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store

# Built frontend bundle (produced by `npm run build` → copied to backend/static)
src/netcopilot/dashboard/backend/static/

# Demo runs: commit facts + manifest, not generated model/findings
demo/campus/model/
demo/campus/findings/
demo/branch/model/
demo/branch/findings/
demo/l2-campus/model/
demo/l2-campus/findings/
